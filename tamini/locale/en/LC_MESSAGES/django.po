msgid "طلب #%(order_id)s - جهز الطلب الآن!"
msgstr "Order #%(order_id)s - Prepare the order now!"

msgid "طلب جديد متاح #%(order_id)s"
msgstr "New order available #%(order_id)s"

msgid "عذراً، لا يمكنك تتبع هذا الطلب."
msgstr "Sorry, you cannot track this order."

msgid "عذراً، هذا الطلب غير موجود أو تم إلغاؤه"
msgstr "Sorry, this order does not exist or has been cancelled."

msgid "غير مسموح لك بإلغاء هذا الطلب"
msgstr "You are not allowed to cancel this order"

msgid "كود التحقق - طعمني"
msgstr "Verification Code - Tamini"

msgid "كود التحقق الجديد الخاص بك هو: %(otp)s"
msgstr "Your new verification code is: %(otp)s"

msgid "كود التحقق الخاص بك هو: %(otp)s"
msgstr "Your verification code is: %(otp)s"

msgid "كود التحقق غير صحيح. يرجى المحاولة مرة أخرى."
msgstr "Incorrect verification code. Please try again."

msgid "كود تحقق جديد - طعمني"
msgstr "New Verification Code - Tamini"

msgid "لا يمكن إلغاء الطلب بعد بدء التحضير."
msgstr "Cannot cancel order after preparation has started."

msgid "لا يمكنك حذف هذا التصنيف."
msgstr "You cannot delete this category."

msgid "لم يتم تعيين سائق بعد. سيتم التحديث عند تعيين سائق."
msgstr "No driver assigned yet. Will update when a driver is assigned."

msgid "ليس لديك صلاحية لإلغاء هذا الطلب."
msgstr "You do not have permission to cancel this order."

msgid "ليس لديك صلاحية لتعديل هذا الطلب."
msgstr "You do not have permission to modify this order."

msgid "مطعم %(username)s"
msgstr "%(username)s Restaurant"

msgid "هذا الطلب تم استلامه من قبل سائق آخر."
msgstr "This order has been taken by another driver."

msgid "هذا الطلب لم يعد موجوداً"
msgstr "This order no longer exists"

msgid "هذا الطلب مكتمل بالفعل."
msgstr "This order is already completed."

msgid "هناك رد جديد على تذكرتك."
msgstr "There is a new reply on your ticket."

msgid "يرجى إدخال رقم الهاتف"
msgstr "Please enter your phone number"

msgid "يرجى إدخال عنوان التوصيل"
msgstr "Please enter your delivery address"

msgid "يرجى الانتظار %(seconds)s ثانية قبل إعادة الإرسال."
msgstr "Please wait %(seconds)s seconds before resending."

msgid "يرجى الانتظار %(seconds)s ثانية قبل إعادة المحاولة."
msgstr "Please wait %(seconds)s seconds before retrying."

msgid "يرجى الانتظار قليلاً قبل تقديم طلب جديد"
msgstr "Please wait a moment before placing a new order"

msgid "💰 طلب #%(order_id)s (دفع عند الاستلام) - جهز الطلب الآن!"
msgstr "💰 Order #%(order_id)s (Cash on delivery) - Prepare the order now!"
